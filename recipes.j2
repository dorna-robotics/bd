{%- set sf = 20 -%}

# Robot (generic): base Recipe with NO component. Owns no station, does no
# boot-time IK — the stable handle for robot-level Start/Park calls
# (park(joint=...), motor). Same across every project.
robot:
  class: workspace.recipes.recipe.Recipe
  kwargs: {speed_factor: {{ sf }}}

# Large tube gripper, parked in the 144 mm tool rack.
gripper:
  class: workspace.recipes.tool_rack.ToolRack
  kwargs: {component: tool_rack_144mm_1, left_approach: true, speed_factor: {{ sf }}}

# Pipettor, parked in the 192 mm tool rack (actions mount it via
# ``tool = "pipettor"``).
pipettor:
  class: workspace.recipes.tool_rack.ToolRack
  kwargs: {component: tool_rack_192mm_1, left_approach: true, speed_factor: {{ sf }}}

# Falcon rack — Rack over the falcon adapter (gripper tube pick/place);
# resolves to rack_falcon_15ml_1.
falcon_rack:
  class: workspace.recipes.rack.Rack
  kwargs: {component: adapter_plate_falcon_15ml_1, left_approach: false, base_distance: 100, rail_step: 25, rail_span: 20, speed_factor: {{ sf }}}

# PipettingSite on the falcon adapter — immerse / aspirate / dispense /
# retract into the rack's tubes. Printer params (base_distance=200).
falcon_pipette:
  class: workspace.recipes.pipetting.PipettingSite
  kwargs: {component: adapter_plate_falcon_15ml_1, base_distance: 200, speed_factor: {{ sf }}}

# Tip rack — pick_tip pulls a fresh tip onto the pipettor.
tip_rack:
  class: workspace.recipes.pipetting.PipettingSite
  kwargs: {component: adapter_sbs_0, base_distance: 250, speed_factor: {{ sf }}}

# Waste bin — eject_tip drops the used tip here.
waste_bin:
  class: workspace.recipes.pipetting.PipettingSite
  kwargs: {component: adapter_sbs_1, base_distance: 250, speed_factor: {{ sf }}}

# Decapper — cap(...) / decap(...) wrap the chunked screw motion
# (printer params: base_distance 200).
decapper:
  class: workspace.recipes.decapper.Decapper
  kwargs: {component: decapper_1, base_distance: 50, rail_step: 25, rail_span: 20, speed_factor: {{ sf }}}

# Cap holder — Rack over its adapter; resolves to capholder_falcon_15ml_1.
capholder:
  class: workspace.recipes.rack.Rack
  kwargs: {component: adapter_capholder_falcon_15ml_1, left_approach: false, base_distance: 50, rail_step: 25, rail_span: 20, speed_factor: {{ sf }}}

# Scale — weight() on the SPX222 (sim-agnostic canned reading by default).
# base_distance 150 + rail 25x20: the plate_1/B4 placement needs the rail
# sweep — the plate_6 params (350/20x5) find no reference joint there.
scale:
  class: workspace.recipes.scale.Scale
  kwargs: {component: scale_spx222_1, base_distance: 50, rail_step: 25, rail_span: 20, speed_factor: {{ sf }}}

# Falcon holder ON the scale — pick/place a tube onto its "place" anchor
# (Scale recipe = base Recipe targeting "place"; same pattern apc used for
# the anode).
scale_holder:
  class: workspace.recipes.scale.Scale
  kwargs: {component: scaletop_falcon_15ml_1, base_distance: 50, rail_step: 25, rail_span: 20, speed_factor: {{ sf }}}

# Camera — present the held tube to the vertical station + detect().
inspector:
  class: workspace.recipes.inspector.FixedInspector
  kwargs: {component: inspection_vertical_144mm_1, base_distance: 200, rail_step: 25, rail_span: 10, detection_preset: {}, speed_factor: {{ sf }}}

# Barcode reader — present() faces the held tube at the reader; detect()
# reads sim-agnostically (canned in sim, real DS457 otherwise).
barcode_reader:
  class: workspace.recipes.barcode_reader.BarcodeReader
  kwargs: {component: barcode_reader_1, base_distance: 200, rail_step: 25, rail_span: 10, speed_factor: {{ sf }}}
